# Alchemy API Key — NFT metadata + RPC calls (eth_blockNumber, alchemy_getAssetTransfers, etc.)
# Get one at https://www.alchemy.com
ALCHEMY_API_KEY=

# Also exposed to the browser for client-side use (wagmi/viem)
NEXT_PUBLIC_ALCHEMY_API_KEY=

# OpenSea API Key — optional, used for enrichment
# Get one at https://docs.opensea.io/reference/api-keys
OPENSEA_API_KEY=
